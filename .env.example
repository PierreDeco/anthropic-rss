# Chemin où le fichier RSS XML sera écrit
# OUTPUT_FILE=~/Library/Application Support/nom/Anthropic/anthropic.xml

# URL de base du site Anthropic
# ANTHROPIC_BASE_URL=https://www.anthropic.com

# Chemin de la page de recherche
# RESEARCH_PATH=/research

# Métadonnées du flux RSS
# RSS_TITLE=Anthropic Research blog
# RSS_DESCRIPTION=The Anthropic Research blog

# Timeout des requêtes HTTP (secondes)
# REQUEST_TIMEOUT=30

# Sélecteurs CSS — à mettre à jour si Anthropic refait son site
# CSS_LIST_CLASS=PublicationList-module-scss-module__KxYrHG__list
# CSS_TITLE_CLASS=PublicationList-module-scss-module__KxYrHG__title body-3
